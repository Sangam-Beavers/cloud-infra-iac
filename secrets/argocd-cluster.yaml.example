# ---------------------------------------------------------------------------
# ArgoCD cluster Secret 템플릿 (stage/prod 공용 — 값은 전부 플레이스홀더).
#
# 실제 값이 채워진 파일은 make onprem-handoff-<env> 가 terraform output에서 자동 생성한다:
#   secrets/.argocd-stage-cluster.yaml / secrets/.argocd-prod-cluster.yaml  (gitignored)
# 온프렘 ArgoCD (devops-system NS) 에 그대로 적용:
#   kubectl -n devops-system apply -f secrets/.argocd-<env>-cluster.yaml
#   argocd cluster list   # server가 Successful 인지 확인
#
# 인증: execProviderConfig가 ArgoCD 내장 argocd-k8s-auth로 EKS 토큰 발급
#   (전용 IAM User sb-<env>-argocd 키 내장, EKS access entry로 네임스페이스 한정 Edit).
# 범위: stringData.namespaces로 ArgoCD가 관리할 NS를 IAM 한정 스코프와 일치시킨다 (전역 list 금지 —
#   안 하면 sync 단계에서 403). namespaces가 설정되면 clusterResources는 기본 false라 생략한다.
#   대상 NS는 install-k8s-stack이 사전 생성한다 (한정 Edit은 NS를 직접 못 만듦).
# 주의: metadata.namespace는 'ArgoCD가 도는 NS' (devops-system, 고정) 이고,
#   stringData.namespaces는 'EKS에서 관리할 대상 NS' (sb-<env>-app-ns) — 서로 다른 값이다.
# 키 회전: terraform taint module.argocd_iam[0].aws_iam_access_key.this && apply 후
#   make onprem-handoff-<env> 재실행 → 재적용.
# ---------------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: <EKS_CLUSTER_NAME>
  namespace: devops-system # ArgoCD가 도는 NS (cluster Secret은 ArgoCD와 같은 NS여야 인식됨 — 고정값)
  labels:
    argocd.argoproj.io/secret-type: cluster
type: Opaque
stringData:
  name: <EKS_CLUSTER_NAME>
  server: https://<EKS_ENDPOINT_HOST>
  namespaces: "<ARGOCD_NAMESPACES>" # EKS에서 ArgoCD가 관리할 대상 NS (IAM 한정 스코프와 일치)
  config: |
    {
      "execProviderConfig": {
        "apiVersion": "client.authentication.k8s.io/v1beta1",
        "command": "argocd-k8s-auth",
        "args": ["aws", "--cluster-name", "<EKS_CLUSTER_NAME>"],
        "env": {
          "AWS_ACCESS_KEY_ID": "<ARGOCD_ACCESS_KEY_ID>",
          "AWS_SECRET_ACCESS_KEY": "<ARGOCD_SECRET_ACCESS_KEY>",
          "AWS_REGION": "<EKS_REGION>"
        }
      },
      "tlsClientConfig": {
        "insecure": false,
        "caData": "<EKS_CA_DATA>"
      }
    }
