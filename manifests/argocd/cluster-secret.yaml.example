# ---------------------------------------------------------------------------
# ArgoCD cluster Secret — 온프렘 ArgoCD가 이 EKS를 배포 대상으로 인식하게 한다.
#
# 채우는 값은 전부 secrets/.argocd-cluster (make onprem-handoff-<env> 산출물) 에 있다.
# <ENV>는 PROD 또는 STAGE. <플레이스홀더>를 그 prefix 값으로 치환 후 ArgoCD 네임스페이스에 apply.
#
# 인증: execProviderConfig가 ArgoCD 이미지 내장 `argocd-k8s-auth aws`로 EKS 토큰을 발급한다.
#   AWS 자격증명은 아래 env에 클러스터별로 내장 (전역 env 불필요 → stage/prod가 서로 다른
#   전용 IAM User 키를 써도 한 ArgoCD에서 안전하게 공존). IAM User는 EKS access entry로
#   네임스페이스 한정 Edit만 부여받는다.
#
# 적용:
#   cp cluster-secret.yaml.example cluster-secret.yaml   # 값 채운 사본은 커밋 금지 (시크릿 포함)
#   kubectl apply -f cluster-secret.yaml                 # ArgoCD 가 도는 클러스터에
# ---------------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: <EKS_CLUSTER_NAME> # 예: sb-stage-eks
  namespace: argocd # ArgoCD 설치 네임스페이스에 맞게
  labels:
    argocd.argoproj.io/secret-type: cluster
type: Opaque
stringData:
  name: <EKS_CLUSTER_NAME>
  server: https://<EKS_ENDPOINT_HOST>
  config: |
    {
      "execProviderConfig": {
        "apiVersion": "client.authentication.k8s.io/v1beta1",
        "command": "argocd-k8s-auth",
        "args": ["aws", "--cluster-name", "<EKS_CLUSTER_NAME>"],
        "env": {
          "AWS_ACCESS_KEY_ID": "<ARGOCD_ACCESS_KEY_ID>",
          "AWS_SECRET_ACCESS_KEY": "<ARGOCD_SECRET_ACCESS_KEY>",
          "AWS_REGION": "<EKS_REGION>"
        }
      },
      "tlsClientConfig": {
        "insecure": false,
        "caData": "<EKS_CA_DATA>"
      }
    }
