# =============================================================================
# production terraform.tfvars 템플릿 (이 .example 파일이 커밋되는 버전)
# -----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 같은 디렉토리의 terraform.tfvars 로 복사한다 (terraform.tfvars는 gitignore됨).
#        cp terraform.tfvars.example terraform.tfvars
#   2) 아래 <...> 플레이스홀더를 실제 결정값으로 채운다. 채우는 기준은 각 항목 주석 참고.
#   3) `terraform plan`으로 in-place/replace 여부를 확인한 뒤 apply.
# 주의:
#   - 여기 값은 "예시/플레이스홀더"다. 실측값 (특히 network CIDR, VPN 토폴로지)은
#     커밋된 채로 두지 말고 terraform.tfvars (gitignore)에만 둔다.
#   - 모든 결정값은 이 파일 한 곳에서만 정한다 (main.tf는 배선만). 환경별 차이 (prod=HA,
#     stage=비용 절감)도 전부 값으로 표현된다.
# =============================================================================

project     = "global-bridge"  # 그대로 둠 (태그·네이밍 접두사).
environment = "production"      # 그대로 둠 (application 스택 ARN 조회 키).
aws_region  = "ap-northeast-2" # 그대로 둠 (서울). 다른 리전은 사실상 신규 배포.
aws_profile = "<AWS_PROFILE>"  # 채울 것: ~/.aws/config 의 프로필 이름 (예: woori-fisa-1k).

# --- 자원 사양/결정값 ---
# nat_gateway_strategy: none (아웃바운드 없음) | single (NAT 1개, 저렴) | per_az (AZ별 NAT, HA).
#   prod 운영은 보통 per_az 권장. single 사용 시 NAT AZ 장애 대비 vpc_config에
#   single_nat_az = "<public AZ 접미사>" 를 추가하면 그 AZ로 재배치 (복구 ~5분). 모듈 validation:
#   single_nat_az는 network.public에 존재하는 AZ여야 함.
vpc_config      = { nat_gateway_strategy = "<none|single|per_az>" }
# deletion_window_in_days: KMS 삭제 예약 대기일 (7~30). prod 운영은 안전 위해 30 권장 (예시는 7).
kms_config      = { deletion_window_in_days = 7 }
# node_type: 캐시 노드 타입 (t4g=ARM). node_count: 총 노드 수 (2+면 Multi-AZ failover).
#   snapshot_retention (선택, 기본 1)도 필요 시 추가. prod HA는 node_count 3, retention 7 권장.
redis_config    = { node_type = "<cache.t4g.micro|...>", node_count = 2 }
# 점프 호스트 (관리 통로) 인스턴스 타입. t4g.small이면 충분 (무상태).
jumphost_config = { instance_type = "t4g.small" }
# EKS 노드: instance_types는 ARM (t4g/m7g)이면 컨테이너 이미지 arm64 필수 (모듈 ami_type 기본 ARM_64).
#   x86으로 가려면 모듈 ami_type도 함께 바꿔야 함. desired/min/max는 트래픽에 맞춰 채울 것.
eks_config      = { instance_types = ["<t4g.medium|m7g.large|...>"], desired_size = 2, min_size = 1, max_size = 6, endpoint_public_access = false }
# Aurora: clusters = 클러스터명 → 논리 DB (서비스) 목록. blast radius 분리를 위해 보통 2개 (core/content).
#   instance_count 1=writer만, 2+=writer+reader (HA). serverless_max_acu (기본 4)/backup_retention_period (기본 1)도
#   필요 시 추가. 예시는 단일 클러스터 1개만 보여줌 — 실제론 core/content 두 개로 채울 것.
aurora_config = {
  clusters       = { "<cluster>" = ["<svc1>", "<svc2>"] }
  instance_count = 2
  # 운영 전환 시: deletion_protection = true, skip_final_snapshot = false (기본은 false / true)
}

# --- 네트워크 설계 (내부 IP 교통 정리표 기준으로 채울 것) ---
# 내부 IP 교통 정리표를 그대로 옮긴다. vpc_cidr (/16) 안에 4계층 서브넷이 모두 포함되고 서로 겹치지 않게.
#   public=인터넷 향, private=앱 (EKS), db=격리 DB/캐시, mgmt=관리/VPN 광고.
#   AZ 키 (a/c/...)는 prod 운영이면 3개 (a/b/c) 권장 (HA). 여기 mgmt 대역은 VPN BGP로 온프렘에 광고되니
#   온프렘 라우팅과 충돌하지 않는 대역을 고를 것. db/private 값은 Aurora/Valkey allowed_cidrs로도 쓰임.
network = {
  vpc_cidr = "<VPC_CIDR>" # 예: 10.0.0.0/16
  public   = { a = "<CIDR>", c = "<CIDR>" }
  private  = { a = "<CIDR>", c = "<CIDR>" }
  db       = { a = "<CIDR>", c = "<CIDR>" }
  mgmt     = { a = "<CIDR>", c = "<CIDR>" }
}

# --- VPN 토폴로지 (온프렘 pfSense 설정과 합 맞춤) ---
# 온프렘 pfSense와 양쪽 합이 맞아야 터널이 붙는다. 채울 때 반드시 온프렘 담당과 값을 맞출 것:
#   - address (우리 EC2 측 터널 IP/28) 와 peer_ip (pfSense 측 터널 IP)는 같은 /28 안의 짝.
#   - listen_port (WG UDP)는 양쪽 동일. active/standby가 다른 포트 (51820/51821).
#   - peer_pubkey_ssm 은 온프렘 공개키가 저장된 SSM 파라미터 "이름"(접두사 /sb/prod/vpn 하위). 키 이름은 보통 고정.
#   - 우리 측 WG 키는 `make vpn-keys-prod`로 SSM에 먼저 등록한 뒤 apply할 것 (user_data가 부팅 시 fetch).
vpn_tunnels = {
  wg0active = {
    address         = "<EC2_TUNNEL_IP>/28" # 예: 10.255.0.1/28
    peer_ip         = "<PFSENSE_ACTIVE_TUNNEL_IP>"
    listen_port     = 51820
    peer_pubkey_ssm = "onprem-active-pub"
  }
  wg1standby = {
    address         = "<EC2_TUNNEL_IP>/28"
    peer_ip         = "<PFSENSE_STANDBY_TUNNEL_IP>"
    listen_port     = 51821
    peer_pubkey_ssm = "onprem-standby-pub"
  }
}
# 관례: wg0active의 EC2 측 터널 IP를 그대로 router-id로 (라우터 식별자, 충돌 주의).
vpn_bgp_router_id = "<WG0ACTIVE_EC2_TUNNEL_IP>"
# 온프렘이 광고하는 사내망 대역 (들). WG AllowedIPs + mgmt return 라우트 대상. 온프렘 실제 대역과 일치시킬 것.
vpn_onprem_cidrs   = ["<ONPREM_CIDR_1>", "<ONPREM_CIDR_2>"]
# pfSense NAT source IP. 비대칭 라우팅 방지 policy routing 대상. 온프렘 pfSense NAT 설정값과 동일하게 채울 것.
vpn_pfsense_nat_ip = "<PFSENSE_NAT_IP>"
